# Optional: enable OpenAI-backed AI insight/chat/report.
# The app still works without this key by using local fallback analysis.
OPENAI_API_KEY=

# Recommended for login/session security. Generate a long random string for real deploys.
SECRET_KEY=change-me-local-dev

# Optional: override SQLite file location. Useful for deploys with persistent disks.
# Local default if omitted: finance.db in the project root.
DB_PATH=

# Comma-separated emails that can download DB backups and restore DB.
ADMIN_EMAILS=

# Keep true for local/demo. Set false on public deployments unless the admin should seed sample data.
ENABLE_DEMO_DATA=true

# Keep false by default on public deployments. Turn on temporarily only when restoring a trusted DB backup.
ENABLE_DB_RESTORE=false

# CSV/restore upload size limit in MB.
MAX_UPLOAD_MB=5

# Set true only when serving over HTTPS in production.
SESSION_COOKIE_SECURE=false

# Optional: override the OpenAI model used by the app if you change app.py.
# Current app default: gpt-4.1-mini
